
{
  "entities": {
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a squad or team division within the club.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the team."
        },
        "name": {
          "type": "string",
          "description": "Team name in English (e.g., Team A)."
        },
        "nameZh": {
          "type": "string",
          "description": "Team name in Chinese (e.g., 隊伍A)."
        }
      },
      "required": [
        "id",
        "name",
        "nameZh"
      ]
    },
    "Kit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Kit",
      "type": "object",
      "description": "Represents a team uniform/kit.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the kit."
        },
        "name": {
          "type": "string",
          "description": "Kit name (e.g., Home 1)."
        },
        "nameZh": {
          "type": "string",
          "description": "Kit name in Chinese."
        },
        "color": {
          "type": "string",
          "description": "Kit color description (e.g., Pink/Grey)."
        },
        "colorZh": {
          "type": "string",
          "description": "Kit color description in Chinese."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL or Data URI to the kit reference image."
        },
        "colorClass": {
          "type": "string",
          "description": "Tailwind color class for the badge (e.g., text-pink-500)."
        }
      },
      "required": [
        "id",
        "name",
        "imageUrl"
      ]
    },
    "Player": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Player",
      "type": "object",
      "description": "Represents a football player within the SquadFlow application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Player entity (Firebase Auth UID)."
        },
        "name": {
          "type": "string",
          "description": "The full name of the player."
        },
        "nickname": {
          "type": "string",
          "description": "A common or preferred nickname for the player."
        },
        "number": {
          "type": "integer",
          "description": "The player's squad or jersey number (Optional)."
        },
        "email": {
          "type": "string",
          "description": "The player's email address."
        },
        "mobileNumber": {
          "type": "string",
          "description": "The player's mobile contact number."
        },
        "preferredPositions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["GK", "DF", "MF", "FW"]
          },
          "description": "The player's preferred positions on the field."
        },
        "teams": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "The IDs of the teams the player belongs to."
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Injured", "Not Available", "Pending for Club Fee", "Trial"],
          "description": "The current status of the player."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the player has administrative privileges."
        },
        "isCaptain": {
          "type": "boolean",
          "description": "Whether the player is designated as a team captain."
        }
      },
      "required": [
        "id",
        "name",
        "teams",
        "status"
      ]
    },
    "Game": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Game",
      "type": "object",
      "description": "Represents a scheduled football game or training session.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Game entity."
        },
        "date": {
          "type": "string",
          "description": "The date when the game is scheduled to take take place.",
          "format": "date"
        },
        "startTime": {
          "type": "string",
          "description": "The start time of the event."
        },
        "endTime": {
          "type": "string",
          "description": "The end time of the event."
        },
        "location": {
          "type": "string",
          "description": "The physical location or address where the game will be played."
        },
        "type": {
          "type": "string",
          "enum": ["Training", "League", "Friendly", "Internal"],
          "description": "The type of game."
        },
        "team": {
          "type": "string",
          "description": "The ID of the team this fixture is for, or 'All'."
        },
        "opponent": {
          "type": "string",
          "description": "The name of the opposing team (if applicable)."
        },
        "kitColors": {
          "type": "string",
          "description": "The ID of the primary kit assigned for this game."
        },
        "alternativeKitColors": {
          "type": "string",
          "description": "The ID of the alternative kit assigned for this game."
        },
        "coach": {
          "type": "string",
          "description": "The name of the coach for this game."
        },
        "fee": {
          "type": "string",
          "description": "The fee associated with the game."
        },
        "additionalDetails": {
          "type": "string",
          "description": "Optional extra notes for the game."
        }
      },
      "required": [
        "id",
        "date",
        "startTime",
        "endTime",
        "location",
        "type",
        "team"
      ]
    },
    "PlayerGameAttendance": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlayerGameAttendance",
      "type": "object",
      "description": "Records a player's attendance status for a specific game.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the PlayerGameAttendance entity (matches playerUid)."
        },
        "playerId": {
          "type": "string",
          "description": "Reference to the Player attending the game."
        },
        "gameId": {
          "type": "string",
          "description": "Reference to the Game for which attendance is recorded."
        },
        "status": {
          "type": "string",
          "enum": ["Confirmed", "Declined", "Pending"],
          "description": "The attendance status."
        },
        "lastUpdated": {
          "type": "string",
          "description": "Timestamp indicating when the status was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "playerId",
        "gameId",
        "status",
        "lastUpdated"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/teams/{teamId}",
        "definition": {
          "entityName": "Team",
          "schema": {
            "$ref": "#/backend/entities/Team"
          },
          "description": "Stores dynamic team types/divisions.",
          "params": [
            {
              "name": "teamId",
              "description": "Unique team ID."
            }
          ]
        }
      },
      {
        "path": "/kits/{kitId}",
        "definition": {
          "entityName": "Kit",
          "schema": {
            "$ref": "#/backend/entities/Kit"
          },
          "description": "Stores team kit details and images.",
          "params": [
            {
              "name": "kitId",
              "description": "Unique kit ID."
            }
          ]
        }
      },
      {
        "path": "/players/{playerUid}",
        "definition": {
          "entityName": "Player",
          "schema": {
            "$ref": "#/backend/entities/Player"
          },
          "description": "Stores individual player profiles. playerUid is the Auth UID.",
          "params": [
            {
              "name": "playerUid",
              "description": "Firebase Auth UID."
            }
          ]
        }
      },
      {
        "path": "/games/{gameId}",
        "definition": {
          "entityName": "Game",
          "schema": {
            "$ref": "#/backend/entities/Game"
          },
          "description": "Stores details for scheduled games.",
          "params": [
            {
              "name": "gameId",
              "description": "Unique game ID."
            }
          ]
        }
      },
      {
        "path": "/games/{gameId}/attendanceRecords/{playerUid}",
        "definition": {
          "entityName": "PlayerGameAttendance",
          "schema": {
            "$ref": "#/backend/entities/PlayerGameAttendance"
          },
          "description": "Records an individual player's attendance status for a specific game.",
          "params": [
            {
              "name": "gameId",
              "description": "Game ID."
            },
            {
              "name": "playerUid",
              "description": "Player's Auth UID."
            }
          ]
        }
      }
    ]
  }
}
