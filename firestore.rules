
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/players/$(request.auth.uid)).data.isAdmin == true;
    }

    function matchesEmail(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- Collection Rules ---

    /**
     * @description Dynamic team management.
     */
    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    /**
     * @description Player profiles. 
     */
    match /players/{playerUid} {
      allow get, list: if isSignedIn();
      
      allow create: if isSignedIn() && (isOwner(playerUid) || isAdmin()) && request.resource.data.id == playerUid;
      
      allow update: if (
        isExistingOwner(playerUid) || 
        isExistingAdmin() || 
        (resource != null && matchesEmail(resource.data.email))
      ) && request.resource.data.id == resource.data.id;
      
      allow delete: if isExistingAdmin() || (resource != null && matchesEmail(resource.data.email));
    }

    /**
     * @description Game and session schedules.
     */
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isAdmin();
      allow update, delete: if isExistingAdmin();

      match /attendanceRecords/{playerUid} {
        allow get, list: if isSignedIn();
        allow create: if (isOwner(playerUid) || isAdmin()) && request.resource.data.playerId == playerUid && request.resource.data.gameId == gameId;
        allow update: if (isExistingOwner(playerUid) || isExistingAdmin()) && request.resource.data.playerId == resource.data.playerId;
        allow delete: if isExistingAdmin();
      }
    }
  }
}
