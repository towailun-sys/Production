rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Robust isAdmin check. 
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/players/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/players/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // --- Collection Rules ---

    // Player profiles: Any signed-in user can read to allow for login validation and roster viewing.
    // Owners and admins can write.
    match /players/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(playerId) || isAdmin();
      allow update: if isOwner(playerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Teams: Public read for signed-in members, managed by admins.
    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Kits: Public read for signed-in members, managed by admins.
    match /kits/{kitId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Games: Public read for signed-in members, managed by admins.
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Attendance Records: Stored inside games for easy roster viewing.
    match /games/{gameId}/attendanceRecords/{playerId} {
      allow get, list: if isSignedIn();
      allow write, delete: if isOwner(playerId) || isAdmin();
    }

    // Support for Collection Group queries on attendanceRecords.
    // This is critical for the "My Attendance" view to filter by playerId across all games.
    match /{path=**}/attendanceRecords/{recordId} {
      // Allow list operations if the user is filtering by their own ID or is an admin.
      allow list: if isSignedIn() && (
        resource.data.playerId == request.auth.uid || 
        recordId == request.auth.uid || 
        isAdmin()
      );
      allow get: if isSignedIn();
      allow write, delete: if isOwner(recordId) || isAdmin();
    }

    // User-centric attendance path for "My Attendance" view (legacy/additional support).
    match /users/{userId}/game_attendances/{attendanceId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow write: if (isOwner(userId) && request.resource.data.playerId == userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // System roles (Read-only for signed-in, managed by service accounts/external).
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow write: if false; 
    }
  }
}