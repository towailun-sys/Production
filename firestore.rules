rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/players/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/players/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // --- Collection Rules ---

    // Root-level allow for signed-in users
    match /players/{playerId} {
      allow read, list: if isSignedIn();
      allow write: if isOwner(playerId) || isAdmin();
    }

    match /games/{gameId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();

      match /attendanceRecords/{playerId} {
        allow read, list: if isSignedIn();
        allow write: if isOwner(playerId) || isAdmin();
      }
    }

    match /teams/{teamId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /kits/{kitId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId}/game_attendances/{attendanceId} {
      allow read, list, write: if isOwner(userId) || isAdmin();
    }

    // --- Collection Group Rules ---
    // Required for finding a specific player's attendance across all games.
    match /{path=**}/attendanceRecords/{recordId} {
      allow read, list: if isSignedIn();
    }
  }
}