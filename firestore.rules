rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/players/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/players/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // --- Collection Rules ---

    // Global Read: Allow all signed-in squad members to read data for transparency.
    // This also covers collection group queries for attendanceRecords if they are nested anywhere.
    match /{path=**} {
      allow read, list: if isSignedIn();
    }

    // Explicit Collection Group Rule: Required for queries across all 'attendanceRecords' subcollections.
    match /{path=**}/attendanceRecords/{recordId} {
      allow read, list: if isSignedIn();
    }

    // Restricted Writes: Only owners or admins can modify data.
    match /players/{playerId} {
      allow create: if isOwner(playerId) || isAdmin();
      allow update: if isOwner(playerId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow write: if isAdmin();
    }

    match /kits/{kitId} {
      allow write: if isAdmin();
    }

    match /games/{gameId} {
      allow write: if isAdmin();
    }

    match /games/{gameId}/attendanceRecords/{playerId} {
      allow write, delete: if isOwner(playerId) || isAdmin();
    }

    match /users/{userId}/game_attendances/{attendanceId} {
      allow write: if (isOwner(userId) && request.resource.data.playerId == userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /roles_admin/{userId} {
      allow write: if false; 
    }
  }
}