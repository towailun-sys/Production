
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/players/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/players/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    function matchesEmail(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- Collection Rules ---

    /**
     * @description Dynamic team management.
     */
    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Team uniform/kit management.
     */
    match /kits/{kitId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Player profiles. 
     */
    match /players/{playerUid} {
      allow get, list: if isSignedIn();
      
      allow create: if isSignedIn() && (isOwner(playerUid) || isAdmin());
      
      allow update: if (
        isExistingOwner(playerUid) || 
        isExistingAdmin() || 
        (resource != null && matchesEmail(resource.data.email))
      );
      
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Game and session schedules.
     */
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /attendanceRecords/{playerUid} {
        allow get, list: if isSignedIn();
        allow create: if (isOwner(playerUid) || isAdmin());
        allow update: if (isExistingOwner(playerUid) || isExistingAdmin());
        allow delete: if isAdmin();
      }
    }
  }
}
