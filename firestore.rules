rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Robust isAdmin check. 
     * Checks roles_admin collection OR the player's own profile field.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/players/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/players/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // --- Collection Rules ---

    // Player profiles: Everyone can read, owners and admins can write.
    match /players/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(playerId) || isAdmin());
      allow update: if isOwner(playerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Teams & Kits: Public read for members, managed by admins.
    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /kits/{kitId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Games: Public read for members, managed by admins.
    match /games/{gameId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Attendance Records: Stored inside games for easy roster viewing.
    match /games/{gameId}/attendanceRecords/{playerId} {
      allow get, list: if isSignedIn();
      allow write: if isOwner(playerId) || isAdmin();
    }

    // User-centric attendance path (for 'My Attendance' screen).
    match /users/{userId}/game_attendances/{attendanceId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow write: if (isOwner(userId) && request.resource.data.playerId == userId) || isAdmin();
    }

    // Support for Collection Group queries on attendance.
    match /{path=**}/game_attendances/{attendanceId} {
      allow list: if isAdmin();
    }

    // System roles.
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow write: if false; // Managed manually or via Cloud Functions.
    }
  }
}